# Copy to .env and adjust for your machine.

# Source document (.pdf or .txt) placed in data/
CONSTITUTION_SOURCE=data/Constitution of India.pdf
CONSTITUTION_TEXT_CACHE=data/constitution.txt

# Vector store (one DB, two collections for the two strategies)
CHROMA_DB_DIR=chroma_db
CHROMA_COLLECTION_NAIVE=constitution_naive
CHROMA_COLLECTION_STRUCTURED=constitution_structured

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
MAX_ARTICLE_CHARS=2500

# Embeddings (must match between ingest and query)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBED_DEVICE=auto            # auto | cuda | cpu
EMBED_BATCH=64

# Reranker (cross-encoder)
RERANK_ENABLED=1
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Retrieval
RAG_HYBRID=1                 # 1 = query both collections then rerank
RAG_STRATEGY=structured      # single-collection fallback: naive | structured
RETRIEVE_K=20                # candidates pulled per collection
TOP_N=6                      # passages kept after rerank
N_RESULTS=4                  # used only on the single-strategy path

# Conversational chat
QUERY_REWRITE=1              # rewrite follow-ups to standalone queries (uses history)
CHAT_HISTORY_TURNS=6         # recent messages fed to the rewriter and answer prompt

# Inference LLM (Ollama)
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_HOST=http://127.0.0.1:11434
